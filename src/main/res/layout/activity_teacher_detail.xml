<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F9F1"
    android:gravity="center_horizontal">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#254D78">

        <ImageView
            android:id="@+id/imgTeacherProfile"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerInParent="true"
            android:src="@drawable/images"
            android:background="@android:color/white"
            android:padding="5dp" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@android:color/white"
        android:elevation="5dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTeacherNameDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اسم الأستاذ"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#254D78"
            android:layout_gravity="center" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginVertical="15dp" />

        <TextView
            android:id="@+id/tvTeacherInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="التخصص: هندسة برمجيات\n\nالمكتب: مبنى A - طابق 2\n\nالساعات المكتبية: 10:00 - 12:00\n\nالبريد: teacher@university.edu"
            android:textSize="16sp"
            android:lineSpacingExtra="8dp"
            android:textColor="#555555" />
    </LinearLayout>

    <Button
        android:id="@+id/btnBackFromDetail"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="رجوع للأساتذة"
        android:backgroundTint="#254D78"
        android:textColor="#FFFFFF" />

</LinearLayout>